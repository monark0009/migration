{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfmigration009"
		},
		"LS_ADLS_PARQUET_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_PARQUET'"
		},
		"LS_ONPREM_SQLSERVER_DW_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_ONPREM_SQLSERVER_DW'"
		},
		"LS_SQLTABLE_MAX_VALUE_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQLTABLE_MAX_VALUE'"
		},
		"LS_SQLTABLE_WATERMARK_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQLTABLE_WATERMARK'"
		},
		"LS_ADLS_PARQUET_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsmigration009.dfs.core.windows.net/"
		},
		"LS_ONPREM_SQLSERVER_DW_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-SPFUOTO"
		},
		"LS_ONPREM_SQLSERVER_DW_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "tables"
		},
		"LS_ONPREM_SQLSERVER_DW_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "monark"
		},
		"LS_SQLTABLE_MAX_VALUE_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-SPFUOTO"
		},
		"LS_SQLTABLE_MAX_VALUE_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "tables"
		},
		"LS_SQLTABLE_MAX_VALUE_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "monark"
		},
		"LS_SQLTABLE_WATERMARK_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-SPFUOTO"
		},
		"LS_SQLTABLE_WATERMARK_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "tables"
		},
		"LS_SQLTABLE_WATERMARK_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "monark"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfmigration009_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_PARQUET_accountKey": {
						"value": "[parameters('LS_ADLS_PARQUET_accountKey')]"
					},
					"LS_ONPREM_SQLSERVER_DW_password": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_DW_password')]"
					},
					"LS_SQLTABLE_MAX_VALUE_password": {
						"value": "[parameters('LS_SQLTABLE_MAX_VALUE_password')]"
					},
					"LS_SQLTABLE_WATERMARK_password": {
						"value": "[parameters('LS_SQLTABLE_WATERMARK_password')]"
					},
					"LS_ADLS_PARQUET_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_PARQUET_properties_typeProperties_url')]"
					},
					"LS_ONPREM_SQLSERVER_DW_properties_typeProperties_server": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_DW_properties_typeProperties_server')]"
					},
					"LS_ONPREM_SQLSERVER_DW_properties_typeProperties_database": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_DW_properties_typeProperties_database')]"
					},
					"LS_ONPREM_SQLSERVER_DW_properties_typeProperties_userName": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_DW_properties_typeProperties_userName')]"
					},
					"LS_SQLTABLE_MAX_VALUE_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLTABLE_MAX_VALUE_properties_typeProperties_server')]"
					},
					"LS_SQLTABLE_MAX_VALUE_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLTABLE_MAX_VALUE_properties_typeProperties_database')]"
					},
					"LS_SQLTABLE_MAX_VALUE_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLTABLE_MAX_VALUE_properties_typeProperties_userName')]"
					},
					"LS_SQLTABLE_WATERMARK_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLTABLE_WATERMARK_properties_typeProperties_server')]"
					},
					"LS_SQLTABLE_WATERMARK_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLTABLE_WATERMARK_properties_typeProperties_database')]"
					},
					"LS_SQLTABLE_WATERMARK_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLTABLE_WATERMARK_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}